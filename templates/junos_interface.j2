/*
 * Generated by Ansible from Nautobot source-of-truth.
 * Device: {{ device_name }}
 */
interfaces {
    {{ iface_name }} {
        description "Managed by Nautobot/Ansible";
        mtu {{ iface_mtu }};
        unit 0 {
            family inet {
                address {{ iface_ip }};
            }
        }
    }
}
