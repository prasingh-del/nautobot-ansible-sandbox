# Copy to .env.local and fill in real values. .env.local is gitignored.

# Observium REST API (HTTP Basic Auth = your AD login)
export OBSERVIUM_URL="https://sun-observium01-p.zooxlabs.com"
export OBSERVIUM_USER="your-username"
export OBSERVIUM_PASSWORD="your-password"

# Cacti — guest Weathermap works without a Console password
export CACTI_URL="https://cacti.zooxlabs.com"
export CACTI_MODE="guest"
export CACTI_WEATHERMAP_PATH="plugins/weathermap/weathermap-cacti-plugin.php"
export CACTI_USER="your-username"
export CACTI_PASSWORD=""
export CACTI_VERIFY_SSL="false"

# Production Nautobot (READ-ONLY use only)
export NAUTOBOT_URL="https://nautobot.zooxlabs.com"
export NAUTOBOT_TOKEN="your-nautobot-token"

# MX204 test device (READ-ONLY Ansible access)
export MX204_HOST="10.0.0.1"
export MX204_USER="admin"
export MX204_PASSWORD="your-device-password"
# Optional: which Nautobot device name to compare against (defaults to box hostname)
export MX204_NAUTOBOT_NAME=""
